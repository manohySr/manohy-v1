---
import type { Project } from '../types';
import github from './../assets/icons/github.svg?raw';
import link from './../assets/icons/link.svg?raw';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="ar-wrapper">

  <button class="ar-toggle" aria-expanded="false" aria-controls="ar-table">
    <span class="ar-text" data-i18n="archive.show">Show Archive</span>
    <span class="ar-arrow" aria-hidden="true">→</span>
  </button>

  <div class="ar-table-wrapper" id="ar-table" hidden>
    <table class="ar-table">
      <thead>
        <tr>
          <th data-i18n="archive.col.project">Project</th>
          <th data-i18n="archive.col.built">Built with</th>
          <th data-i18n="archive.col.links">Links</th>
        </tr>
      </thead>
      <tbody>
        {
          projects.map((project) => (
            <tr>
              <td class="ar-name">{project.name}</td>
              <td class="ar-tech">
                {project.technologies.map((tech, i) => (
                  <span>
                    {tech}
                    {i < project.technologies.length - 1 ? ' · ' : ''}
                  </span>
                ))}
              </td>
              <td class="ar-links">
                {project.github && project.github !== '#' && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.name} GitHub`}
                  >
                    <Fragment set:html={github} />
                  </a>
                )}
                {project.live && (
                  <a
                    href={project.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.name} live site`}
                  >
                    <Fragment set:html={link} />
                  </a>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

</div>

<script>
  const toggle = document.querySelector('.ar-toggle');
  const table  = document.querySelector('#ar-table');

  const archiveLabels: Record<string, Record<string, string>> = {
    en: { show: 'Show Archive', hide: 'Hide Archive' },
    fr: { show: "Voir l'archive", hide: "Masquer l'archive" },
  };

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    table?.toggleAttribute('hidden');

    const text  = toggle.querySelector('.ar-text');
    const arrow = toggle.querySelector('.ar-arrow');
    if (text) {
      const lang = document.documentElement.lang || 'en';
      const newKey = isExpanded ? 'show' : 'hide';
      text.setAttribute('data-i18n', isExpanded ? 'archive.show' : 'archive.hide');
      text.textContent = archiveLabels[lang]?.[newKey] ?? text.textContent;
    }
    if (arrow) arrow.textContent = isExpanded ? '→' : '↑';
  });
</script>

<style is:global>
  .ar-wrapper {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  /* ── Toggle button ── */
  .ar-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .ar-toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-secondary);
  }

  .ar-arrow {
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .ar-toggle[aria-expanded='true'] .ar-arrow {
    transform: rotate(-90deg);
  }

  /* ── Table ── */
  .ar-table-wrapper {
    width: 100%;
    overflow-x: auto;
  }

  .ar-table {
    width: 100%;
    border-collapse: collapse;
  }

  .ar-table thead th {
    text-align: left;
    padding: 0.5rem 1rem 0.5rem 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    font-weight: 400;
  }

  .ar-table tbody tr {
    border-bottom: 1px solid var(--color-border-light);
    transition: background-color 0.15s ease;
  }

  .ar-table tbody tr:hover {
    background-color: var(--color-card);
  }

  .ar-table td {
    padding: 0.75rem 1rem 0.75rem 0;
    vertical-align: middle;
  }

  .ar-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .ar-tech {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .ar-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .ar-links a,
  .ar-links a:link,
  .ar-links a:visited {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ar-links a:hover {
    color: var(--color-text-primary);
  }

  .ar-links svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
  }

  @media (max-width: 768px) {
    .ar-table thead th:nth-child(2),
    .ar-table td:nth-child(2) {
      display: none;
    }
  }
</style>
