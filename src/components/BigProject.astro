---
import type { Project } from '../types';
import Github from './../assets/icons/github.svg?raw';
import Link from './../assets/icons/link.svg?raw';
import { Image } from 'astro:assets';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const { name, description, technologies, github, live, image } = project;
const isEven = index % 2 === 0;
---

<div class={`big-project-container ${isEven ? '' : 'reverse'}`}>
  <div class="project-image">
    <a href={live || github} target="_blank" rel="noopener noreferrer">
      {image ? (
        <Image
          src={image}
          alt={`${name} screenshot`}
          width={800}
          height={600}
          format="webp"
          quality={90}
        />
      ) : (
        <img
          src="https://via.placeholder.com/800x600"
          alt={`${name} screenshot`}
        />
      )}
    </a>
  </div>

  <div class="project-content">
    <h5 class="project-overline">Featured Project</h5>
    <h3 class="project-title">
      <a href={live || github} target="_blank" rel="noopener noreferrer">
        {name}
      </a>
    </h3>

    <div class="project-description">
      <p>{description}</p>
    </div>

    <ul class="project-tech-list">
      {technologies.map((tech) => (
        <li>{tech}</li>
      ))}
    </ul>
  </div>
</div>

<style>
  .big-project-container {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 8rem;
    position: relative;
    padding: 2rem 0;
  }

  .big-project-container.reverse {
    direction: rtl;
  }

  .big-project-container.reverse .project-content {
    direction: ltr;
  }

  .big-project-container.reverse .project-description {
    text-align: left;
  }


.project-image {
  position: relative;
  z-index: 1;
  border-radius: 0.75rem;
  overflow: hidden; /* ensures rounded corners clip image */
  filter: grayscale(100%);
}

.project-image:hover {
  filter: grayscale(0%);
}

.project-image a {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 0.5rem;
  overflow: hidden;
  position: relative;
}

.project-image a img {
  width: 100%;
  height: 100%;
  object-fit: cover; /* ensures image covers container */
  display: block;
}



  .project-image:hover::before {
    opacity: 0.4;
  }

  .project-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 0.5rem;
    transition: transform 0.3s ease;
  }

  .project-image:hover img {
    transform: scale(1.02);
  }

  .project-overline {
    margin: 0 1rem 1rem 0;
    color: #64b5f6;
    font-family: monospace;
    font-size: 0.875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }


  .project-title {
    color: #1a1a1a;
    font-size:  1.4rem;
    margin: 0 0 1.5rem;
    font-weight: 700;
  }

  .project-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.25s ease;
  }

  .project-title a:hover {
    color: #64b5f6;
  }

  .project-description {
    position: relative;
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  .project-description p {
    color: #64748b;
    font-size: 1.125rem;
    line-height: 1.8;
    margin: 0;
  }

  .project-tech-list {
    display: flex;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
    margin: 0 0 1.5rem 0;
    padding: 0;
    list-style: none;
    gap: 0.75rem;
  }

  .project-tech-list li {
    font-family: monospace;
    font-size: 0.875rem;
    padding: 0.25rem 0.75rem;
    background: rgba(100, 181, 246, 0.1);
    border: 1px solid rgba(100, 181, 246, 0.2);
    border-radius: 0.25rem;
    color: #64748b;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .project-tech-list li:hover {
    background: rgba(100, 181, 246, 0.2);
    border-color: #64b5f6;
    color: #64b5f6;
  }

  .project-links {
    display: flex;
    align-items: center;
    position: relative;
    gap: 1rem;
  }

  .project-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    color: #64748b;
    background: rgba(100, 181, 246, 0.05);
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .project-links a:hover {
    color: #64b5f6;
    background: rgba(100, 181, 246, 0.15);
    transform: translateY(-2px);
  }

  .project-links svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }

  @media (max-width: 1080px) {
    .big-project-container {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .big-project-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
      padding: 1rem 0;
    }

    .big-project-container.reverse {
      direction: ltr;
    }

    .project-image {
      padding: 1.5rem;
    }

    .project-title {
      font-size: 1.75rem;
    }

    .project-description p {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .project-tech-list {
      gap: 0 10px;
    }

    .project-tech-list li {
      font-size: 0.75rem;
    }
  }
</style>
