---
import type { Project } from '../types';
import Github from './../assets/icons/github.svg?raw';
import Link from './../assets/icons/link.svg?raw';
import { Image } from 'astro:assets';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const { name, description, descriptionFr, technologies, github, live, image } = project;
const num = String(index + 1).padStart(2, '0');
---

<article class="bp-card">

  <div class="bp-image">
    <a href={live || github} target="_blank" rel="noopener noreferrer">
      {
        image ? (
          <Image
            src={image}
            alt={`${name} screenshot`}
            width={800}
            height={600}
            format="webp"
            quality={90}
          />
        ) : (
          <div class="bp-placeholder"></div>
        )
      }
    </a>
  </div>

  <div class="bp-content">
    <div class="bp-header">
      <span class="bp-num">{num}</span>
      <span class="bp-sep" aria-hidden="true">·</span>
      <span class="bp-overline" data-i18n="projects.overline">Featured Project</span>
    </div>

    <h3 class="bp-title">
      <a href={live || github} target="_blank" rel="noopener noreferrer">
        {name}
      </a>
    </h3>

    <p class="bp-desc">
      <span data-lang="en">{description}</span>
      <span data-lang="fr" style="display:none">{descriptionFr ?? description}</span>
    </p>

    <ul class="bp-tech">
      {technologies.map((tech) => <li>{tech}</li>)}
    </ul>

    <div class="bp-links">
      {github && github !== '#' && (
        <a
          href={github}
          class="bp-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${name} on GitHub`}
        >
          <Fragment set:html={Github} />
        </a>
      )}
      {live && (
        <a
          href={live}
          class="bp-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${name} live site`}
        >
          <Fragment set:html={Link} />
        </a>
      )}
    </div>
  </div>

</article>

<style is:global>
  .bp-card {
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    transition: background 0.2s ease;
  }

  .bp-card:hover {
    background: var(--color-card);
  }

  /* ── Image ── */
  .bp-image {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    filter: grayscale(100%);
    transition: filter 0.4s ease;
  }

  .bp-card:hover .bp-image {
    filter: grayscale(0%);
  }

  .bp-image a {
    display: block;
    height: 100%;
  }

  .bp-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .bp-card:hover .bp-image img {
    transform: scale(1.03);
  }

  .bp-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-card);
  }

  /* ── Content ── */
  .bp-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .bp-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bp-num,
  .bp-sep,
  .bp-overline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .bp-overline {
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .bp-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .bp-title a,
  .bp-title a:link,
  .bp-title a:visited {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bp-title a:hover {
    color: var(--color-text-secondary);
  }

  .bp-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  /* ── Tech pills ── */
  .bp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bp-tech li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .bp-tech li:hover {
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }

  /* ── Links ── */
  .bp-links {
    display: flex;
    gap: 1rem;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .bp-link,
  .bp-link:link,
  .bp-link:visited {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bp-link:hover {
    color: var(--color-text-primary);
  }

  .bp-link svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
  }

  @media (max-width: 768px) {
    .bp-content {
      padding: 1.5rem;
    }
  }
</style>
