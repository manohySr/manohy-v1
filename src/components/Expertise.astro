---
import Layout from '../layout/Layout.astro';
import { expertise } from '../data';
---

<Layout>
  <section class="ex-section" id="expertise">

    <div class="ex-meta">
      <h2 class="ex-label" data-i18n="expertise.label">Expertise</h2>
      <span class="ex-num" aria-hidden="true">02</span>
    </div>

    <div class="ex-rule" aria-hidden="true"></div>

    <div class="ex-layout">

      <div class="ex-left">
        <p class="ex-desc" data-i18n="expertise.desc">
          I build web products end-to-end — turning ideas into real, working
          software. From responsive interfaces to AI-powered backends.
        </p>
        <a href="#featured-projects" class="ex-link" data-i18n="expertise.link">
          See my work →
        </a>
      </div>

      <div class="ex-grid">
        {
          expertise.map((area, i) => (
            <div class="ex-card">
              <span class="ex-card-num">0{i + 1}</span>
              <h3 class="ex-card-title">
                <span data-lang="en">{area.title}</span>
                <span data-lang="fr" style="display:none">{area.titleFr ?? area.title}</span>
              </h3>
              <p class="ex-card-desc">
                <span data-lang="en">{area.description}</span>
                <span data-lang="fr" style="display:none">{area.descriptionFr ?? area.description}</span>
              </p>
              <ul class="ex-card-list">
                {area.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  .ex-section {
    padding: 6rem 0 8rem;
  }

  /* ── Meta row ── */
  .ex-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .ex-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: 0;
  }

  .ex-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  /* ── Rule ── */
  .ex-rule {
    width: 100%;
    height: 1px;
    background: var(--color-border);
    margin-bottom: 4rem;
  }

  /* ── Split layout ── */
  .ex-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── Left column ── */
  .ex-left {
    position: sticky;
    top: 7rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .ex-desc {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
  }

  .ex-link,
  .ex-link:link,
  .ex-link:visited {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    width: fit-content;
    transition: border-color 0.2s ease;
  }

  .ex-link:hover {
    border-color: var(--color-text-primary);
  }

  /* ── Card grid ── */
  .ex-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  /* 3rd card spans full width when alone in its row */
  .ex-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .ex-card {
    background: var(--color-bg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.2s ease;
  }

  .ex-card:hover {
    background: var(--color-card);
  }

  .ex-card-num {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .ex-card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ex-card-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .ex-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ex-card-list li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ex-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .ex-left {
      position: static;
    }

    .ex-grid {
      grid-template-columns: 1fr;
    }

    .ex-card:last-child:nth-child(odd) {
      grid-column: auto;
    }
  }
</style>
