---
import { siteConfig } from '../data/index';

const navItems = [
  { label: 'Home', href: '#' },
  { label: 'Expertise', href: '#expertise' },
  { label: 'Projects', href: '#featured-projects' },
  { label: 'About', href: '#about' },
  { label: 'Resume', href: siteConfig.cvUrl, external: true },
  { label: 'Contact', href: 'mailto:manohyrajaonah@gmail.com', external: true },
];
---

<header class="hd-bar">
  <a href="/" class="hd-logo">@manohySr</a>

  <ul class="hd-nav" role="list">
    {
      navItems.map(({ label, href, external }) => (
        <li>
          <a
            href={href}
            {...(external
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            {label}
            {external ? ' ↗' : ''}
          </a>
        </li>
      ))
    }
  </ul>

  <button class="hd-burger" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
  </button>
</header>

<div class="hd-overlay" id="hd-overlay">
  <button class="hd-overlay-close" aria-label="Close menu">
    <span></span>
    <span></span>
  </button>

  <nav class="hd-overlay-nav">
    <ul role="list">
      {
        navItems.map(({ label, href, external }, i) => (
          <li style={`--i: ${i}`}>
            <a
              href={href}
              {...(external
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              <span class="hd-overlay-num">0{i + 1}</span>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script type="module">
  const burger = document.querySelector('.hd-burger');
  const overlay = document.querySelector('#hd-overlay');
  const closeBtn = document.querySelector('.hd-overlay-close');
  const overlayLinks = document.querySelectorAll('.hd-overlay-nav a');

  function openMenu() {
    overlay.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlayLinks.forEach((link) => link.addEventListener('click', closeMenu));
</script>

<style is:global>
  /* ── Bar ── */
  .hd-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Logo ── */
  .hd-logo,
  .hd-logo:link,
  .hd-logo:visited {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  /* ── Desktop nav ── */
  .hd-nav {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2.5rem;
    align-items: center;
  }

  .hd-nav a,
  .hd-nav a:link,
  .hd-nav a:visited {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .hd-nav a:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }

  /* ── Burger ── */
  .hd-burger {
    display: none;
    position: relative;
    width: 24px;
    height: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .hd-burger span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-text-primary);
    transform-origin: center;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .hd-burger span:nth-child(1) {
    top: 0;
  }
  .hd-burger span:nth-child(2) {
    bottom: 0;
  }

  .hd-burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6.25px) rotate(45deg);
  }

  .hd-burger[aria-expanded='true'] span:nth-child(2) {
    transform: translateY(-6.25px) rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  .hd-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hd-overlay.is-open {
    transform: translateX(0);
  }

  /* Close button — X icon */
  .hd-overlay-close {
    position: absolute;
    top: 1.25rem;
    right: 2.5rem;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .hd-overlay-close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 22px;
    height: 1.5px;
    background: var(--color-text-primary);
  }

  .hd-overlay-close span:nth-child(1) {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .hd-overlay-close span:nth-child(2) {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  /* ── Overlay nav ── */
  .hd-overlay-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hd-overlay-nav li {
    border-top: 1px solid var(--color-border);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .hd-overlay-nav li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .hd-overlay.is-open .hd-overlay-nav li {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.3s ease calc(var(--i) * 55ms + 80ms),
      transform 0.3s ease calc(var(--i) * 55ms + 80ms);
  }

  .hd-overlay-nav a,
  .hd-overlay-nav a:link,
  .hd-overlay-nav a:visited {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.1rem 0;
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hd-overlay-nav a:hover {
    color: var(--color-text-primary);
  }

  .hd-overlay-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hd-nav {
      display: none;
    }

    .hd-burger {
      display: block;
    }
  }
</style>
