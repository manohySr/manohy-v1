---
import { siteConfig } from '../data/index';

const navItems = [
  { label: 'Home',       href: '#home',              i18nKey: 'nav.home'      },
  { label: 'Expertise',  href: '#expertise',         i18nKey: 'nav.expertise' },
  { label: 'Projects',   href: '#featured-projects', i18nKey: 'nav.projects'  },
  { label: 'About',      href: '#about',             i18nKey: 'nav.about'     },
  { label: 'Resume ↗',   href: siteConfig.cvUrl, external: true, i18nKey: 'nav.resume'  },
  { label: 'Contact',    href: '#contact',           i18nKey: 'nav.contact'   },
];
---

<header class="hd-bar">
  <a href="/" class="hd-logo">@manohySr</a>

  <ul class="hd-nav" role="list">
    {
      navItems.map(({ label, href, external, i18nKey }) => (
        <li>
          <a
            href={href}
            data-i18n={i18nKey}
            {...(external
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>

  <button class="hd-lang" aria-label="Switch language">FR</button>

  <button class="hd-burger" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
  </button>
</header>

<div class="hd-overlay" id="hd-overlay">

  <nav class="hd-overlay-nav">
    <ul role="list">
      {
        navItems.map(({ label, href, external, i18nKey }, i) => (
          <li style={`--i: ${i}`}>
            <a
              href={href}
              data-i18n={i18nKey}
              {...(external
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              <span class="hd-overlay-num">0{i + 1}</span>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script type="module">
  const burger = document.querySelector('.hd-burger');
  const overlay = document.querySelector('#hd-overlay');
  const overlayLinks = document.querySelectorAll('.hd-overlay-nav a');

  function openMenu() {
    overlay.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger?.addEventListener('click', () => {
    const isOpen = burger.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });
  overlayLinks.forEach((link) => link.addEventListener('click', closeMenu));

  // Language toggle
  const langBtn = document.querySelector('.hd-lang');
  langBtn?.addEventListener('click', () => {
    const current = document.documentElement.lang || 'en';
    const next = current === 'en' ? 'fr' : 'en';
    window.__setLang?.(next);
  });

  // Active section highlight
  const sections = document.querySelectorAll('section[id], footer[id]');
  const desktopLinks = document.querySelectorAll('.hd-nav a[href^="#"]');

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        desktopLinks.forEach((link) => {
          link.classList.remove('is-active');
          if (link.getAttribute('href') === `#${entry.target.id}`) {
            link.classList.add('is-active');
          }
        });
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });

  sections.forEach((s) => sectionObserver.observe(s));
</script>

<style is:global>
  /* ── Bar ── */
  .hd-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Logo ── */
  .hd-logo,
  .hd-logo:link,
  .hd-logo:visited {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  /* ── Desktop nav ── */
  .hd-nav {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2.5rem;
    align-items: center;
  }

  .hd-nav a,
  .hd-nav a:link,
  .hd-nav a:visited {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .hd-nav a:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }

  .hd-nav a.is-active,
  .hd-nav a.is-active:link,
  .hd-nav a.is-active:visited {
    color: var(--color-text-primary);
    border-color: var(--color-text-primary);
  }

  /* ── Lang toggle ── */
  .hd-lang {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    background: var(--color-text-primary);
    color: var(--color-bg);
    border: 1px solid var(--color-text-primary);
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .hd-lang:hover {
    background: transparent;
    color: var(--color-text-primary);
  }

  /* ── Burger ── */
  .hd-burger {
    display: none;
    position: relative;
    width: 24px;
    height: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .hd-burger span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-text-primary);
    transform-origin: center;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .hd-burger span:nth-child(1) {
    top: 0;
  }
  .hd-burger span:nth-child(2) {
    bottom: 0;
  }

  .hd-burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6.25px) rotate(45deg);
  }

  .hd-burger[aria-expanded='true'] span:nth-child(2) {
    transform: translateY(-6.25px) rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  .hd-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hd-overlay.is-open {
    transform: translateX(0);
  }

  /* ── Overlay nav ── */
  .hd-overlay-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hd-overlay-nav li {
    border-top: 1px solid var(--color-border);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .hd-overlay-nav li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .hd-overlay.is-open .hd-overlay-nav li {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.3s ease calc(var(--i) * 55ms + 80ms),
      transform 0.3s ease calc(var(--i) * 55ms + 80ms);
  }

  .hd-overlay-nav a,
  .hd-overlay-nav a:link,
  .hd-overlay-nav a:visited {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.1rem 0;
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hd-overlay-nav a:hover {
    color: var(--color-text-primary);
  }

  .hd-overlay-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hd-nav {
      display: none;
    }

    .hd-burger {
      display: block;
    }
  }
</style>
