---
import github from './../assets/icons/github.svg?raw';
import linkedin from './../assets/icons/linkedin.svg?raw';
import cv from './../assets/icons/cv.svg?raw';
import { siteConfig } from '../data/index';
---

<div class="container">
  <a
    href={siteConfig.cvUrl}
    class="glass-effect"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="View CV"
  >
    <Fragment set:html={cv} />
  </a>
  <a
    href="https://www.github.com/manohysr"
    class="glass-effect"
    target="_blank"
  >
    <Fragment set:html={github} />
  </a>
  <a
    href="https://www.linkedin.com/in/manohy-saotra-rajaonah/"
    class="glass-effect"
    target="_blank"
  >
    <Fragment set:html={linkedin} />
  </a>
</div>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .container a {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10rem;
    border: 1px solid var(--color-text-primary);
    width: 3rem;
    height: 3rem;
    color: white;
    background-color: var(--color-icon-bg);
  }
</style>
